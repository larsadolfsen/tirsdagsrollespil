# Required on Railway/production. The app protects all routes with HTTP Basic Auth
# when NODE_ENV=production or Railway environment variables are present.
WFRP_BASIC_AUTH_USERNAME="wfrp"
WFRP_BASIC_AUTH_PASSWORD="change-me"

# Optional. Set to false only for trusted local/private deployments.
WFRP_REQUIRE_AUTH="true"

# Optional. Override where runtime data is stored. Railway Volume mount path is used
# automatically when RAILWAY_VOLUME_MOUNT_PATH is present.
WFRP_DATA_DIR="/app/data"

# Optional. Tune in-memory API rate limits per client IP per minute.
WFRP_API_RATE_LIMIT_MAX_REQUESTS="120"
WFRP_API_WRITE_RATE_LIMIT_MAX_REQUESTS="30"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# PAGESPEED_API_KEY: Optional. Used by `npm run pagespeed` to increase Google
# PageSpeed Insights API quota.
PAGESPEED_API_KEY="MY_PAGESPEED_API_KEY"
