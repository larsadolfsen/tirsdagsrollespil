#!/bin/sh

if [ "$ALLOW_DATA_PUSH" = "1" ]; then
  exit 0
fi

zero_sha="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    changed_paths="$(git diff-tree --no-commit-id --name-only -r "$local_sha" -- data)"
  else
    changed_paths="$(git diff --name-only "$remote_sha" "$local_sha" -- data)"
  fi

  if [ -n "$changed_paths" ]; then
    cat <<EOF
Push blocked: outgoing commits change protected runtime data under data/.

$changed_paths

This protects Railway Volume data and local character saves from accidental seed-data pushes.
If this is intentional, rerun with:
  ALLOW_DATA_PUSH=1 git push ...
EOF
    exit 1
  fi
done

exit 0
